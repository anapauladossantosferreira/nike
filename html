<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Exemplo de Loja</title>
    <style>
        body { font-family: 'Helvetica', sans-serif; background-color: #f5f5f5; }
        .produto-card {
            width: 300px;
            background: white;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .produto-imagem {
            width: 100%;
            height: auto;
        }
        .categoria { color: #757575; font-size: 14px; }
        .nome-produto { font-weight: bold; font-size: 18px; margin: 5px 0; }
        .preco { font-weight: bold; color: #000; }
    </style>
</head>
<body>

    <div class="produto-card">
        <img src="https://via.placeholder.com/300" alt="Tenis Esportivo" class="produto-imagem">
        <p class="categoria">Calçado Masculino</p>
        <h2 class="nome-produto">Tênis de Performance</h2>
        <p class="preco">R$ 599,99</p>
    </div>

</body>
</html>