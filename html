<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nike - Calçados, Roupas e Acessórios</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: "Helvetica Neue", Arial, sans-serif; }
        header { border-bottom: 1px solid #e5e5e5; padding: 0 48px; height: 60px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; background: white; z-index: 100; }
        .nav-menu a { text-decoration: none; color: #000; font-weight: 600; margin: 0 12px; font-size: 16px; }
        
        .main-content { display: flex; padding: 40px 48px; }
        .sidebar { width: 260px; padding-right: 20px; }
        .sidebar h3 { font-size: 24px; margin-bottom: 20px; }
        .sidebar-item { list-style: none; line-height: 2.2; font-weight: 500; cursor: pointer; }

        .products-grid { flex: 1; display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; }
        .card { text-decoration: none; color: #000; margin-bottom: 30px; }
        .card-img { width: 100%; aspect-ratio: 1/1; background: #f6f6f6; object-fit: cover; }
        .card-info { padding: 12px 0; }
        .tag { color: #9e3500; font-weight: bold; font-size: 14px; }
        .name { font-weight: 600; font-size: 16px; margin: 4px 0; }
        .cat { color: #757575; font-size: 15px; }
        .price { font-weight: 600; margin-top: 10px; font-size: 16px; }
    </style>
</head>
<body>

<header>
    <img src="https://upload.wikimedia.org/wikipedia/commons/a/a6/Logo_NIKE.svg" width="60">
    <div class="nav-menu">
        <a href="#">Lançamentos</a>
        <a href="#">Masculino</a>
        <a href="#">Feminino</a>
        <a href="#">Ofertas</a>
    </div>
    <div style="font-size: 12px; font-weight: bold;">CARRINHO (0)</div>
</header>

<div class="main-content">
    <div class="sidebar">
        <h3>Calçados (240)</h3>
        <ul>
            <li class="sidebar-item">Lifestyle</li>
            <li class="sidebar-item">Corrida</li>
            <li class="sidebar-item">Treino e Academia</li>
            <li class="sidebar-item">Basquete</li>
            <li class="sidebar-item">Futebol</li>
        </ul>
    </div>

    <div class="products-grid">
        <div class="card">
            <img src="https://imgnike-a.akamaihd.net/750x750/0219805A.jpg" class="card-img" alt="Nike Dunk">
            <div class="card-info">
                <span class="tag">Lançamento</span>
                <div class="name">Nike Dunk Low Retro</div>
                <div class="cat">Calçado Masculino</div>
                <div class="price">R$ 899,99</div>
            </div>
        </div>
        <div class="card">
            <img src="https://imgnike-a.akamaihd.net/750x750/026365BP.jpg" class="card-img" alt="Air Force 1">
            <div class="card-info">
                <span class="tag">Best Seller</span>
                <div class="name">Nike Air Force 1 '07</div>
                <div class="cat">Calçado Feminino</div>
                <div class="price">R$ 799,99</div>
            </div>
        </div>
        <div class="card">
            <img src="https://imgnike-a.akamaihd.net/750x750/02703851.jpg" class="card-img" alt="Air Max">
            <div class="card-info">
                <span style="color: #fff">.</span>
                <div class="name">Nike Air Max Pulse</div>
                <div class="cat">Calçado Masculino</div>
                <div class="price">R$ 1.199,99</div>
            </div>
        </div>
    </div>
</div>

</body>
</html>